# 服务器配置

# 服务端口
PORT=8123

# Qwen API Key（阿里云百炼）
# 获取地址：https://bailian.console.aliyun.com/
# ⚠️ 重要：填写真实 API Key 后，此文件不会提交到 Git
QWEN_API_KEY=your_qwen_api_key_here

# 允许的 CORS 来源（多个用逗号分隔）
ALLOWED_ORIGINS=*

# 日志级别 (info, debug, warn, error)
LOG_LEVEL=info

# ==================== Cloudflare D1 数据库配置 ====================
# 
# Cloudflare 账号信息（等待主人提供）
# CF_ACCOUNT_ID=your_account_id
# CF_DATABASE_ID=your_database_id
# CF_API_TOKEN=your_api_token
#
# 或者使用 Workers 绑定（推荐）
# DATABASE_BINDING=DB

# ==================== 配置说明 ====================
# 
# 1. 复制此文件为 .env
# 2. 填写真实的 QWEN_API_KEY
# 3. .env 文件已加入 .gitignore，不会提交到 Git
#
# 使用方法：
# cp .env.example .env
# # 然后编辑 .env 填写真实配置
